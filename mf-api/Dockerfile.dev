FROM node:22-slim

WORKDIR /app

# Install openssl for Prisma and other dev tools if needed
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

COPY package*.json ./

RUN npm install

# Copy Prisma schema and config
COPY prisma ./prisma
COPY prisma.config.js ./

# Generate Prisma Client
RUN npx prisma generate

# Copy the rest of the source
COPY . .

EXPOSE 3000

# Start the dev server
# We use sh -c to allow multiple commands if needed, 
# although npm run dev is usually enough as it handles nodemon.
CMD ["npm", "run", "dev"]