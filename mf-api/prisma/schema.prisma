generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        Int      @id @default(autoincrement())
    email     String   @unique
    password  String
    credits   Int      @default(100)
    // links Link[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
